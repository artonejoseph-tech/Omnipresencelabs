<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omnipresence Labs | Premium US PCBA & Fast-Turn Prototyping</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .tech-gradient {
            background: radial-gradient(circle at top right, #1e293b 0%, #0f172a 100%);
        }
        .glow-effect:hover {
            box-shadow: 0 0 15px rgba(34, 211, 238, 0.4);
        }
        /* Formspree state styling blocks */
        [data-fs-success], [data-fs-error] {
            display: none;
        }
        .fs-success [data-fs-success] {
            display: block;
        }
        .fs-success form {
            display: none;
        }
        .fs-error [data-fs-error] {
            display: block;
        }
    </style>
</head>
<body class="bg-slate-950 font-sans text-slate-100 antialiased">

    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur-md sticky top-0 z-50">
