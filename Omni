            <div class="text-xl md:text-2xl font-black tracking-wider text-cyan-400">
                OMNIPRESENCE<span class="text-white font-light">LABS</span>
            </div>
            <nav class="flex items-center space-x-8">
                <a href="#specs" class="hidden md:inline text-sm text-slate-400 hover:text-cyan-400 transition">Capabilities</a>
                <a href="#workflow" class="hidden md:inline text-sm text-slate-400 hover:text-cyan-400 transition">Process</a>
                <a href="#quote" class="glow-effect bg-cyan-500 hover:bg-cyan-400 text-slate-950 px-5 py-2 rounded font-bold text-sm transition tracking-wide">
                    Submit RFQ
                </a>
            </nav>
        </div>
    </header>

    <section class="tech-gradient relative py-24 px-6 overflow-hidden border-b border-slate-900">
